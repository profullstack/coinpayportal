// в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// в”Ђв”Ђ Reputation commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

async function handleReputation(subCommand, args) {
  const opts = parseArgs(args);
  switch (subCommand) {
    case 'profile': {
      const did = opts._positional?.[0] || opts.did;
      if (!did) {
        console.error('Usage: coinpay reputation profile <did>');
        process.exit(1);
      }
      const res = await fetch(`${API_BASE}/api/reputation/agent/${encodeURIComponent(did)}/reputation`);
      const data = await res.json();
      if (!data.success) {
        console.error('Error:', data.error);
        process.exit(1);
      }
      console.log('\nрџ“Љ Reputation Profile:', did);
      if (data.trust_vector) {
        console.log('\nрџ”· Trust Vector (CPTL v2):');
        console.log(`  E (Economic):    ${data.trust_vector.E}`);
        console.log(`  P (Productivity): ${data.trust_vector.P}`);
        console.log(`  B (Behavioral):  ${data.trust_vector.B}`);
        console.log(`  D (Diversity):   ${data.trust_vector.D}`);
        console.log(`  R (Recency):     ${data.trust_vector.R}`);
        console.log(`  A (Anomaly):     ${data.trust_vector.A}`);
        console.log(`  C (Compliance):  ${data.trust_vector.C}`);
      }
      if (data.reputation?.windows) {
        const w = data.reputation.windows.all_time;
        console.log('\nрџ“€ All-Time Stats:');
        console.log(`  Tasks: ${w.task_count}  Accepted: ${w.accepted_count}  Disputed: ${w.disputed_count}`);
        console.log(`  Volume: $${w.total_volume.toFixed(2)}  Unique Buyers: ${w.unique_buyers}`);
      }
      if (data.reputation?.anti_gaming?.flagged) {
        console.log('\nвљ пёЏ  Anti-gaming flags:', data.reputation.anti_gaming.flags.join(', '));
      }
      break;
    }
    case 'claim': {
      // Import and use the reputation claim functionality
      const { CoinPayClient } = await import('../packages/sdk/src/client.js');
      const { claimDid, getMyDid } = await import('../packages/sdk/src/reputation.js');
      
      const apiKey = opts['api-key'] || process.env.COINPAY_API_KEY;
      const jwt = opts.jwt || process.env.COINPAY_JWT_TOKEN;

      if (!apiKey && !jwt) {
        console.error('Error: --api-key or --jwt required');
        console.error('Set COINPAY_API_KEY or COINPAY_JWT_TOKEN environment variable');
        process.exit(1);
      }

      try {
        const client = new CoinPayClient({
          apiKey: apiKey || undefined,
          bearerToken: jwt || undefined,
          baseUrl: `${API_BASE}/api`,
        });

        console.log('рџ”ђ Checking existing DID...');
        
        // Check if DID already exists
        let existingDid;
        try {
          existingDid = await getMyDid(client);
          console.log(`вњ… Found existing DID: ${existingDid.did}`);
          console.log(`   Public Key: ${existingDid.public_key}`);
          console.log(`   Verified: ${existingDid.verified ? 'вњ… Yes' : 'вќЊ No'}`);
          console.log(`   Created: ${existingDid.created_at}`);
          
          const reputationUrl = `${API_BASE}/api/reputation/agent/${encodeURIComponent(existingDid.did)}/reputation`;
          console.log(`   Reputation: ${reputationUrl}`);
          return;
        } catch (error) {
          if (!error.message.includes('not found')) {
            throw error;
          }
        }

        console.log('рџљЂ Claiming new DID...');
        
        const result = await claimDid(client);
        
        console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
        console.log('в•‘                          DID CLAIMED                            в•‘');
        console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
        console.log(`в•‘  DID:        ${result.did}`);
        console.log(`в•‘  Public Key: ${result.public_key}`);
        console.log(`в•‘  Verified:   ${result.verified ? 'вњ… Yes' : 'вќЊ No'}`);
        console.log(`в•‘  Created:    ${result.created_at}`);
        console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
        
        const reputationUrl = `${API_BASE}/api/reputation/agent/${encodeURIComponent(result.did)}/reputation`;
        console.log(`рџ”Ќ **View Reputation:** ${reputationUrl}`);
        console.log(`рџ“Љ **Badge URL:** ${API_BASE}/api/reputation/badge/${encodeURIComponent(result.did)}`);
        
        console.log('\nрџ’Ў **Next Steps:**');
        console.log('  вЂў Submit task receipts to build reputation');
        console.log('  вЂў Add DID to your platform profiles');
        console.log('  вЂў Share reputation URL with clients');
        console.log(`  вЂў Use this DID: ${result.did}`);

      } catch (error) {
        const msg = error?.response
          ? formatError(error.response.error || error.response.message || error.response)
          : formatError(error);
        console.error('\nвќЊ **DID Claim Failed:**', msg);
        
        if (msg.includes('Unauthorized')) {
          console.error('\nTip: Verify your API key or JWT token is correct and has merchant permissions.');
        } else if (msg.includes('already has a DID')) {
          console.error('\nTip: Each merchant can only have one DID. Use `coinpay reputation profile <did>` to view existing.');
        }
        
        process.exit(1);
      }
      break;
    }
    case 'help': case '--help': case '-h': default:
      console.log(`
Reputation Commands:
  coinpay reputation profile <did>       Show trust vector and reputation for a DID
  coinpay reputation claim [--api-key]   Claim a new DID for your merchant account
`);
      break;
  }
}

// в”Ђв”Ђ Card commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

function getCoinPayClient() {
  const apiKey = process.env.COINPAY_API_KEY;
  if (!apiKey) {
    throw new Error('COINPAY_API_KEY environment variable required');
  }
  return new CoinPayClient({ 
    apiKey,
    baseUrl: API_BASE + '/api'
  });
}

async function handleCard(subCommand, args) {
  const opts = parseArgs(args);
  
  const commands = {
    pay: cardPay,
    escrow: cardEscrow,
    escrows: cardEscrows,
    release: cardRelease,
    refund: cardRefund,
    transactions: cardTransactions,
    balance: cardBalance,
  };

  const command = commands[subCommand];
  if (command) {
    await command(opts);
  } else {
    console.error(`Unknown card command: ${subCommand || '(none)'}`);
    showCardHelp();
    process.exit(1);
  }
}

async function cardPay(opts) {
  const { business, amount, description } = opts;
  if (!business || !amount || !description) {
    console.error('Error: --business, --amount, and --description are required');
    console.error('Usage: coinpay card pay --business <id> --amount <usd> --description "text"');
    process.exit(1);
  }

  try {
    const client = getCoinPayClient();
    const payment = await createQuickCardPayment(client, business, parseFloat(amount), description);
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘            CARD PAYMENT CREATED         в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    console.log(`в•‘  Amount:      ${formatCardAmount(Math.round(parseFloat(amount) * 100))}`);
    console.log(`в•‘  Business:    ${business}`);
    console.log(`в•‘  Description: ${description}`);
    console.log(`в•‘  Payment ID:  ${payment.id || payment.session_id || 'N/A'}`);
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
    console.log(`рџ”— Checkout URL: ${payment.checkout_url || payment.url}\n`);
  } catch (err) {
    console.error('Error creating payment:', formatError(err));
    process.exit(1);
  }
}

async function cardEscrow(opts) {
  const { business, amount, description } = opts;
  if (!business || !amount || !description) {
    console.error('Error: --business, --amount, and --description are required');
    console.error('Usage: coinpay card escrow --business <id> --amount <usd> --description "text"');
    process.exit(1);
  }

  try {
    const client = getCoinPayClient();
    const escrow = await createCardEscrow(client, business, parseFloat(amount), description);
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘            CARD ESCROW CREATED           в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    console.log(`в•‘  Amount:      ${formatCardAmount(Math.round(parseFloat(amount) * 100))}`);
    console.log(`в•‘  Business:    ${business}`);
    console.log(`в•‘  Description: ${description}`);
    console.log(`в•‘  Escrow ID:   ${escrow.id || escrow.session_id || 'N/A'}`);
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
    console.log(`рџ”— Checkout URL: ${escrow.checkout_url || escrow.url}\n`);
    console.log('рџ’Ў Funds will be held in escrow until released.');
  } catch (err) {
    console.error('Error creating escrow:', formatError(err));
    process.exit(1);
  }
}

async function cardEscrows(opts) {
  const { business, status, limit } = opts;
  
  try {
    const client = getCoinPayClient();
    const options = {};
    if (business) options.businessId = business;
    if (status) options.status = status;
    if (limit) options.limit = parseInt(limit);
    
    const result = await listCardEscrows(client, options);
    const escrows = result.escrows || result.data || [];
    
    if (escrows.length === 0) {
      console.log('No card escrows found.');
      return;
    }
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘                          CARD ESCROWS                           в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    
    escrows.forEach((escrow, i) => {
      if (i > 0) console.log('в•џв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•ў');
      
      const amount = escrow.amount || escrow.amount_cents;
      const status = escrow.status || escrow.escrow_status || 'unknown';
      const statusIcon = {
        pending: 'рџџЎ',
        released: 'рџџў',
        refunded: 'рџ”ґ',
        disputed: 'рџџ '
      }[status] || 'вљЄ';
      
      console.log(`в•‘  ID:          ${escrow.id || 'N/A'}`);
      console.log(`в•‘  Amount:      ${formatCardAmount(amount)}`);
      console.log(`в•‘  Status:      ${statusIcon} ${status.toUpperCase()}`);
      console.log(`в•‘  Business:    ${escrow.business_id || escrow.businessId || 'N/A'}`);
      console.log(`в•‘  Description: ${escrow.description || 'N/A'}`);
      console.log(`в•‘  Created:     ${escrow.created_at || escrow.createdAt || 'N/A'}`);
    });
    
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
  } catch (err) {
    console.error('Error listing escrows:', formatError(err));
    process.exit(1);
  }
}

async function cardRelease(opts) {
  const escrowId = opts._positional[0];
  if (!escrowId) {
    console.error('Error: Escrow ID is required');
    console.error('Usage: coinpay card release <escrowId>');
    process.exit(1);
  }

  try {
    const client = getCoinPayClient();
    const result = await releaseCardEscrow(client, escrowId);
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘          ESCROW RELEASED                 в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    console.log(`в•‘  Escrow ID:   ${escrowId}`);
    console.log(`в•‘  Status:      рџџў RELEASED`);
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
    console.log('вњ… Funds have been released to the merchant.');
  } catch (err) {
    console.error('Error releasing escrow:', formatError(err));
    process.exit(1);
  }
}

async function cardRefund(opts) {
  const escrowId = opts._positional[0];
  const { partial } = opts;
  
  if (!escrowId) {
    console.error('Error: Escrow ID is required');
    console.error('Usage: coinpay card refund <escrowId> [--partial <amount>]');
    process.exit(1);
  }

  try {
    const client = getCoinPayClient();
    const options = {};
    if (partial) {
      options.amount = Math.round(parseFloat(partial) * 100); // Convert to cents
    }
    
    const result = await refundCardEscrow(client, escrowId, options);
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘          ESCROW REFUNDED                 в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    console.log(`в•‘  Escrow ID:   ${escrowId}`);
    console.log(`в•‘  Status:      рџ”ґ REFUNDED`);
    if (partial) {
      console.log(`в•‘  Amount:      ${formatCardAmount(options.amount)} (partial)`);
    }
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
    console.log('рџ’° Refund has been processed.');
  } catch (err) {
    console.error('Error refunding escrow:', formatError(err));
    process.exit(1);
  }
}

async function cardTransactions(opts) {
  const { business, status, limit } = opts;
  
  try {
    // For now, we'll reuse the escrows endpoint since transactions endpoint 
    // would require additional API implementation
    const client = getCoinPayClient();
    const options = {};
    if (business) options.businessId = business;
    if (status) options.status = status;
    if (limit) options.limit = parseInt(limit);
    
    const result = await listCardEscrows(client, options);
    const transactions = result.escrows || result.data || [];
    
    if (transactions.length === 0) {
      console.log('No card transactions found.');
      return;
    }
    
    console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
    console.log('в•‘                       CARD TRANSACTIONS                          в•‘');
    console.log('в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј');
    
    transactions.forEach((tx, i) => {
      if (i > 0) console.log('в•џв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•ў');
      
      const amount = tx.amount || tx.amount_cents;
      const status = tx.status || tx.escrow_status || 'unknown';
      const statusIcon = {
        pending: 'рџџЎ',
        released: 'рџџў',
        refunded: 'рџ”ґ',
        completed: 'вњ…',
        failed: 'вќЊ'
      }[status] || 'вљЄ';
      
      console.log(`в•‘  ID:          ${tx.id || 'N/A'}`);
      console.log(`в•‘  Amount:      ${formatCardAmount(amount)}`);
      console.log(`в•‘  Status:      ${statusIcon} ${status.toUpperCase()}`);
      console.log(`в•‘  Business:    ${tx.business_id || tx.businessId || 'N/A'}`);
      console.log(`в•‘  Description: ${tx.description || 'N/A'}`);
      console.log(`в•‘  Date:        ${tx.created_at || tx.createdAt || 'N/A'}`);
    });
    
    console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
  } catch (err) {
    console.error('Error listing transactions:', formatError(err));
    process.exit(1);
  }
}

